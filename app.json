      "adaptiveIcon": {
        "backgroundColor": "#FFE4EE"
      },
      "package": "com.thrmanager.app"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35
          }
        }
      ]
    ]
  }
}
